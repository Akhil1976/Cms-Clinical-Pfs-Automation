# Copy this file to ".env" and fill in real values. ".env" is never committed to git.

# --- Email notifications (Gmail example) -------------------------------
# 1. Turn on 2-Step Verification on the Gmail account: myaccount.google.com/security
# 2. Create an "App Password": myaccount.google.com/apppasswords
#    (choose app = "Mail", device = "Other", name it e.g. "CLFS bot")
# 3. Put that 16-character app password below — NOT your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your.bot.address@gmail.com
SMTP_PASSWORD=your16charapppassword
NOTIFY_EMAIL_TO=where.alerts.should.go@gmail.com
NOTIFY_EMAIL_FROM=your.bot.address@gmail.com

# --- Scheduling ----------------------------------------------------------
# How often (in days) the "check for new files" job runs.
CLFS_CHECK_INTERVAL_DAYS=3

# --- Data retention --------------------------------------------------------
CLFS_RETENTION_YEARS=3

# --- Optional overrides -----------------------------------------------------
# CLFS_DB_PATH=/absolute/path/to/clfs.db
